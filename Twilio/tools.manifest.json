{
  "name": "Twilio",
  "description": "Twilio provider tools for SMS and messaging notifications.",
  "version": "1.0.0",
  "entry": "./tools.js",
  "pageBound": false,
  "variables": [
    "TWILIO_ACCOUNT_SID",
    "TWILIO_FROM_NUMBER",
    "TWILIO_WHATSAPP_FROM"
  ],
